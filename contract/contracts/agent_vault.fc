#pragma version =0.4.6;

#include "imports/stdlib.fc";

const int error::signature_disabled = 400;
const int error::invalid_seqno = 401;
const int error::invalid_wallet_id = 402;
const int error::invalid_signature = 403;
const int error::expired = 404;
const int error::invalid_prefix = 405;
const int error::agent_revoked = 409;
const int error::agent_key_expired = 410;
const int error::unauthorized = 412;
const int error::invalid_c5 = 413;
const int error::must_have_ignore_errors = 414;

const int size::bool = 1;
const int size::seqno = 32;
const int size::wallet_id = 32;
const int size::public_key = 256;
const int size::valid_until = 32;
const int size::signature = 512;
const int size::query_id = 64;
const int size::msg_flags = 4;

const int prefix::signed_external = 0x7369676E;

const int op::admin_set_agent = 0x61677374;    ;; "agst"
const int op::admin_revoke_agent = 0x6172766B; ;; "arvk"
const int op::admin_set_owner_key = 0x616F776B; ;; "aowk"

const int gas::storage = 100000000;

slice get_last_bits(slice s, int l) asm "SDCUTLAST";
slice remove_last_bits(slice s, int l) asm "SDSKIPLAST";
slice enforce_and_remove_action_send_msg_prefix(slice body) impure asm "x{0ec3c86d} SDBEGINS";
() set_c5_actions(cell action_list) impure asm "c5 POP";
(slice, int) begin_parse_raw(cell c) asm "XCTOS";
int count_trailing_zeroes(slice s) asm "SDCNTTRAIL0";

(int, int, int, int, slice, int, int) load_state() impure inline {
  slice ds = get_data().begin_parse();
  return (
    ds~load_int(size::bool),          ;; signature_allowed
    ds~load_uint(size::seqno),        ;; seqno
    ds~load_uint(size::wallet_id),    ;; wallet_id
    ds~load_uint(size::public_key),   ;; owner_public_key
    ds~load_msg_addr(),               ;; admin_address
    ds~load_uint(size::public_key),   ;; agent_public_key
    ds~load_uint(size::valid_until)   ;; agent_valid_until
  );
}

() save_state(
  int signature_allowed, int seqno, int wallet_id,
  int owner_public_key, slice admin_address,
  int agent_public_key, int agent_valid_until
) impure inline {
  set_data(
    begin_cell()
      .store_int(signature_allowed, size::bool)
      .store_uint(seqno, size::seqno)
      .store_uint(wallet_id, size::wallet_id)
      .store_uint(owner_public_key, size::public_key)
      .store_slice(admin_address)
      .store_uint(agent_public_key, size::public_key)
      .store_uint(agent_valid_until, size::valid_until)
      .end_cell()
  );
}

cell verify_c5_actions(cell c5, int is_external) inline {
  (slice cs, _) = c5.begin_parse_raw();
  int count = 0;

  while (~ cs.slice_empty?()) {
    cs = cs.enforce_and_remove_action_send_msg_prefix();
    throw_unless(error::invalid_c5, cs.slice_bits() == 8);
    throw_unless(error::invalid_c5, cs.slice_refs() == 2);

    throw_if(error::must_have_ignore_errors,
             is_external & (count_trailing_zeroes(cs.preload_bits(7)) > 0));

    (cs, _) = cs.preload_ref().begin_parse_raw();
    count += 1;
  }

  throw_unless(error::invalid_c5, count <= 255);
  throw_unless(error::invalid_c5, cs.slice_refs() == 0);

  return c5;
}

() process_signed_external(slice in_msg_body) impure inline {
  throw_unless(error::invalid_prefix, in_msg_body.preload_uint(32) == prefix::signed_external);

  slice signature = in_msg_body.get_last_bits(size::signature);
  slice signed_slice = in_msg_body.remove_last_bits(size::signature);

  slice cs = signed_slice.skip_bits(32); ;; skip prefix
  int wallet_id = cs~load_uint(size::wallet_id);
  int valid_until = cs~load_uint(size::valid_until);
  int msg_seqno = cs~load_uint(size::seqno);

  (
    int signature_allowed, int stored_seqno, int stored_wallet_id,
    int owner_public_key, slice admin_address,
    int agent_public_key, int agent_valid_until
  ) = load_state();

  throw_if(error::signature_disabled, (~ signature_allowed));
  throw_unless(error::invalid_seqno, msg_seqno == stored_seqno);
  throw_unless(error::invalid_wallet_id, wallet_id == stored_wallet_id);
  throw_if(error::expired, valid_until <= now());

  int message_hash = slice_hash(signed_slice);
  int owner_ok = check_signature(message_hash, signature, owner_public_key);
  int agent_ok = 0;
  if (agent_public_key != 0) {
    agent_ok = check_signature(message_hash, signature, agent_public_key);
  }

  throw_unless(error::invalid_signature, owner_ok | agent_ok);

  if (~ owner_ok) {
    throw_if(error::agent_key_expired, now() > agent_valid_until);
  }

  accept_message();
  stored_seqno += 1;

  save_state(signature_allowed, stored_seqno, stored_wallet_id, owner_public_key, admin_address,
             agent_public_key, agent_valid_until);
  commit();

  cell c5_actions = cs~load_maybe_ref();
  ifnot (cell_null?(c5_actions)) {
    set_c5_actions(c5_actions.verify_c5_actions(true));
  }
}

int is_admin(slice sender, slice admin_address) inline {
  return sender.equal_slices_bits(admin_address);
}

() process_admin_operation(int operation, slice in_msg_body, slice sender) impure inline {
  (
    int signature_allowed, int stored_seqno, int stored_wallet_id,
    int owner_public_key, slice admin_address,
    int agent_public_key, int agent_valid_until
  ) = load_state();

  throw_unless(error::unauthorized, is_admin(sender, admin_address));

  slice cs = in_msg_body.skip_bits(32);
  cs~skip_bits(size::query_id);

  if (operation == op::admin_set_agent) {
    agent_public_key = cs~load_uint(size::public_key);
    agent_valid_until = cs~load_uint(size::valid_until);
    save_state(signature_allowed, stored_seqno, stored_wallet_id, owner_public_key, admin_address,
               agent_public_key, agent_valid_until);
    return ();
  }

  if (operation == op::admin_revoke_agent) {
    save_state(signature_allowed, stored_seqno, stored_wallet_id, owner_public_key, admin_address,
               0, 0);
    return ();
  }

  if (operation == op::admin_set_owner_key) {
    owner_public_key = cs~load_uint(size::public_key);
    save_state(signature_allowed, stored_seqno, stored_wallet_id, owner_public_key, admin_address,
               agent_public_key, agent_valid_until);
    return ();
  }

  throw(0);
}

() recv_external(slice in_msg_body) impure inline {
  process_signed_external(in_msg_body);
}

() recv_internal(cell in_msg_full, slice in_msg_body) impure inline {
  if (in_msg_body.slice_bits() < 32) {
    return ();
  }

  int operation = in_msg_body.preload_uint(32);
  if ((operation != op::admin_set_agent) & (operation != op::admin_revoke_agent) & (operation != op::admin_set_owner_key)) {
    return ();
  }

  raw_reserve(gas::storage, 0);

  slice cs = in_msg_full.begin_parse();
  int flags = cs~load_uint(size::msg_flags);
  if (flags & 1) { return (); }
  slice sender = cs~load_msg_addr();

  process_admin_operation(operation, in_msg_body, sender);
}

int seqno() method_id {
  return get_data().begin_parse().skip_bits(size::bool).preload_uint(size::seqno);
}
